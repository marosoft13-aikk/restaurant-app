```
// Firestore Security Rules — محمية لمحادثات 1:1
// اهداف القواعد:
// - يسمح فقط للمشاركين في الشات بقراءة/كتابة المستند chat doc وقراءة/إنشاء رسائل داخل subcollection.
// - السماح بإنشاء chat جديد فقط إذا المستخدم الذي ينشئه مدرج ضمن participants.
// - يقيد تحديث حقل participants بحيث لا يمكن تغيير قائمة المشاركين بعد الإنشاء (لحماية سلامة المحادثة).
// - يسمح بإنشاء رسالة فقط إذا حقل from يطابق المستخدم المرسل، ويجب أن يكون المرسل مشاركًا في الشات.
// - يسمح بحذف رسالة فقط للمرسل نفسه.
// - يسمح بتحديث حالة الرسالة (مثلاً status -> 'read') من قبل أي مشارك بشرط ألا يغيّروا محتوى الرسالة الأصلي.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users collection: قراءة متاحة للمصادق عليهم، وكتابة فقط للمالك نفسه
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // chats collection (مستند الشات)
    match /chats/{chatId} {
      // Create: يسمح بإنشاء مستند chat جديد فقط إذا:
      // - المستخدم مصادق عليه
      // - request.resource.data.participants موجودة وقائمة (array)
      // - uid للمرسل موجود داخل participants
      // - (اختياري) نتحقق أن participants طولها 2 لمحادثة 1:1
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['participants'])
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // Read: مسموح فقط للمستخدمين الموجودين ضمن participants
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Update: مسموح للمشاركين فقط، لكن لا نسمح بتغيير قائمة participants بعد الإنشاء
      // (أي يجب أن تبقى participants كما هي في resource)
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;

      // Delete: مسموح فقط للمشاركين (راجع سياسة التطبيق إن أردت تقييد الحذف)
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Subcollection: messages
      match /messages/{messageId} {
        // قراءة الرسائل للمشاركين فقط
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/chats/$(chatId))
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // إنشاء رسالة:
        // - المرسل auth.uid يجب أن يكون هو value في حقل 'from'
        // - المرسل يجب أن يكون مشاركًا في الشات
        // - يجب احتواء الحقول الأساسية: from, createdAt, status, type
        // - نوع type يجب أن يكون 'text' أو 'image'
        allow create: if request.auth != null
          && request.resource.data.keys().hasAll(['from', 'createdAt', 'status', 'type'])
          && request.resource.data.from == request.auth.uid
          && (request.resource.data.type == 'text' || request.resource.data.type == 'image')
          && exists(/databases/$(database)/documents/chats/$(chatId))
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // تحديث رسالة: نسمح بتحديثات محدودة مثل تغيير status و readAt
        // لا نسمح بتعديل محتوى الرسالة (text, imageUrl, from, createdAt)
        allow update: if request.auth != null
          && exists(/databases/$(database)/documents/chats/$(chatId))
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && (
            // السماح فقط إذا مفاتيح البيانات المرسلة للتحديث هي subset من: status, readAt
            request.resource.data.keys().hasOnly(['from','createdAt','status','text','type','imageUrl','readAt'])
            &&
            // ولا تسمح بتغيير الحقول الأساسية من قبل غير المالك:
            request.resource.data.from == resource.data.from
            && request.resource.data.createdAt == resource.data.createdAt
          );

        // حذف رسالة: فقط المرسل نفسه يمكنه حذف رسالته
        allow delete: if request.auth != null
          && resource.data.from == request.auth.uid;
      }
    }

    // قواعد افتراضية — يمكن توسيعها حسب الحاجة
  }
}
```